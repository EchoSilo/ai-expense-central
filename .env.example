# Copy this file to .env and fill in your API keys
# The backend server reads these at startup — restart after changes

# OpenAI: requires an org admin key (not a project key)
# Get it at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-org-...

# Anthropic
# Get it at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs
# Get it at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# AssemblyAI
# Get it at: https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=

# HeyGen
# Get it at: https://app.heygen.com/settings?nav=API
HEYGEN_API_KEY=

# Optional: change the backend port (default: 3001)
# SERVER_PORT=3001
